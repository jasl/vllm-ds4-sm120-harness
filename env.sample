# Copy this file to .env and fill local values. Do not commit .env.

# DeepSeek official API reference runs.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_BETA_BASE_URL=https://api.deepseek.com/beta
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_TYPE=enabled
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_PRESERVE_REASONING_CONTENT=1

# Local or remote vLLM service under test.
BASE_URL=http://127.0.0.1:8000
MODEL=deepseek-ai/DeepSeek-V4-Flash
VLLM_BIN=vllm
PYTHON=python

# Benchmark defaults.
CONCURRENCY=1,2,4,8,16,24
DATASET_NAME=hf
DATASET_PATH=philschmid/mt-bench
TOKENIZER_MODE=deepseek_v4
NUM_PROMPTS=80
BENCH_TIMEOUT=1800

# Runtime telemetry defaults.
GPU_STATS=1
GPU_STATS_INTERVAL_SECONDS=1
RUNTIME_STATS=1
RUNTIME_STATS_INTERVAL_SECONDS=5

# B200/H100 reference oracle export defaults.
BASELINE_LABEL=b200_oracle
ORACLE_LOGPROBS=20
ORACLE_TIMEOUT=300
ORACLE_STOP_ON_ERROR=1
ORACLE_CASES=

# Server deadlock guard defaults.
SERVER_GUARD=1
SERVER_STARTUP_TIMEOUT=1800
SERVER_STARTUP_INTERVAL_SECONDS=15
SERVER_HEALTH_TIMEOUT=10
SERVER_FAILURE_PROBE_TIMEOUT=30
SERVER_FAILURE_GRACE_TIMEOUT=300
SERVER_FAILURE_GRACE_INTERVAL_SECONDS=10
SERVER_RECOVERY_CMD=

# Optional artifact controls.
ARTIFACT_ROOT=
BRANCH_NAME=
RUN_TIMESTAMP=
GPU_TOPOLOGY_SLUG=
SERVE_LOG=
