# Copy this file to .env and fill local values. Do not commit .env.

# DeepSeek official API reference runs.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_BETA_BASE_URL=https://api.deepseek.com/beta
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_FLASH_MODEL=deepseek-v4-flash
DEEPSEEK_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING_TYPE=enabled
DEEPSEEK_REASONING_EFFORT=high
DEEPSEEK_PRESERVE_REASONING_CONTENT=1
OFFICIAL_BASELINE_DATE=
OFFICIAL_BASELINE_LABEL=
OFFICIAL_BASELINE_DIR=
OFFICIAL_REQUEST_RETRIES=1
OFFICIAL_REPEAT_COUNT=3
OFFICIAL_TEMPERATURE=1.0
OFFICIAL_TOP_P=1.0
OFFICIAL_GENERATION_PROMPTS=zh_wr_tech_001,en_wr_tech_001,zh_code_fe_001,en_code_be_001,zh2en_tech_001,en2zh_tech_001,zh_sum_tech_001,en_sum_tech_001
OFFICIAL_THINKING_MODES=non-thinking,think-high,think-max
OFFICIAL_SMOKE_CASES=math_7_times_8,capital_of_france,spanish_greeting
OFFICIAL_SMOKE_REPEAT_COUNT=1
OFFICIAL_RUN_TOOLCALL15=1
OFFICIAL_TOOLCALL15_SCENARIO_SET=en
OFFICIAL_TOOLCALL15_THINKING_MODES=non-thinking,think-high,think-max
OFFICIAL_TOOLCALL15_REPEAT_COUNT=1
OFFICIAL_TOOLCALL15_TEMPERATURE=1.0
OFFICIAL_TOOLCALL15_TOP_P=1.0
OFFICIAL_TOOLCALL15_MIN_POINTS=2
OFFICIAL_TOOLCALL15_TIMEOUT=120
OFFICIAL_STRICT=0

# Local or remote vLLM service under test.
BASE_URL=http://127.0.0.1:8000
MODEL=deepseek-ai/DeepSeek-V4-Flash
VLLM_BIN=vllm
PYTHON=python

# Benchmark defaults.
CONCURRENCY=1,2,4,8,16,24
DATASET_NAME=hf
DATASET_PATH=philschmid/mt-bench
TOKENIZER_MODE=deepseek_v4
NUM_PROMPTS=80
BENCH_TIMEOUT=1800
BENCH_TRANSIENT_FAILURE_RETRIES=1

# Runtime telemetry defaults.
GPU_STATS=1
GPU_STATS_INTERVAL_SECONDS=1
RUNTIME_STATS=1
RUNTIME_STATS_INTERVAL_SECONDS=5
VLLM_COLLECT_ENV=1
VLLM_COLLECT_ENV_URL=https://raw.githubusercontent.com/vllm-project/vllm/main/vllm/collect_env.py
VLLM_COLLECT_ENV_DOWNLOAD_TIMEOUT=30
VLLM_COLLECT_ENV_TIMEOUT=180

# B200/H100 reference oracle export defaults.
BASELINE_LABEL=b200_oracle
ORACLE_LOGPROBS=20
ORACLE_TIMEOUT=300
ORACLE_REQUEST_RETRIES=1
ORACLE_STOP_ON_ERROR=1
ORACLE_CASES=

# B200 official/reference baseline automation.
# These paths are evaluated on the reference host running scripts/run_b200_baseline.sh.
B200_VLLM_REPO=/workspace/vllm
B200_VLLM_VENV=/workspace/vllm/.venv
# Include the effective topology/TP shape in public baseline labels, for example
# b200_tp2_main_<sha> or b200_tp4_main_<sha>.
B200_BASELINE_LABEL=b200_tp4_main_5737770c6
B200_BASELINE_VARIANTS=nomtp,mtp
B200_BASELINE_PHASES=all
B200_VARIANT_PARALLEL=0
B200_PARALLEL_GPU_GROUPS=nomtp=0,1;mtp=2,3
B200_PARALLEL_TENSOR_PARALLEL_SIZE=2
B200_PARALLEL_PORTS=
ARTIFACT_ARCHIVE_PREVIOUS=1
# Empty ARTIFACT_ARCHIVE_PREFIX uses B200_BASELINE_LABEL in the B200 baseline driver.
ARTIFACT_ARCHIVE_PREFIX=
B200_TENSOR_PARALLEL_SIZE=4
B200_BLOCK_SIZE=256
B200_KV_CACHE_DTYPE=fp8
SERVE_MAX_MODEL_LEN=393216
# auto enables the SM100/B200-only FP4 indexer cache flag only when detected.
# Keep auto or set 0 on SM12x hosts such as RTX Pro 6000, RTX 5090, and GB10.
SERVE_USE_FP4_INDEXER_CACHE=auto
NO_MTP_CONCURRENCY=1,2,4,8,16,24
MTP_CONCURRENCY=1,2,4,8,16,24
RUN_ACCEPTANCE=1
RUN_KV_LAYOUT_PROBE=1
KV_LAYOUT_CASE_NAME=packed_fp8_indexer_cache_layout
KV_LAYOUT_NUM_BLOCKS=2
KV_LAYOUT_BLOCK_SIZE=256
KV_LAYOUT_HEAD_DIM=448
KV_LAYOUT_SCALE_BYTES=8
KV_LAYOUT_REQUIRE_HELPER_MATCH=1
KV_LAYOUT_TIMEOUT=120
RUN_PREFIX_CACHE_PROBE=1
PREFIX_CACHE_CASE_NAME=prefix_cache_interleaved_long_conversation
PREFIX_CACHE_LINE_COUNT=2400
PREFIX_CACHE_MAX_TOKENS=64
PREFIX_CACHE_TEMPERATURE=0.0
PREFIX_CACHE_TOP_P=1.0
PREFIX_CACHE_THINKING_MODE=non-thinking
PREFIX_CACHE_TIMEOUT=1800
PREFIX_CACHE_REQUEST_RETRIES=1
PREFIX_CACHE_REGRESSION_TTFT_RATIO=3.0
PREFIX_CACHE_FAIL_ON_REGRESSION=0
# Optional short streaming-pressure soak. Keep disabled by default.
RUN_STREAMING_PRESSURE_SOAK=0
STREAMING_PRESSURE_CASE_NAME=streaming_pressure_short_soak
STREAMING_PRESSURE_CONCURRENCY=4
STREAMING_PRESSURE_ROUND_COUNT=3
STREAMING_PRESSURE_LINE_COUNT=1200
STREAMING_PRESSURE_MAX_TOKENS=128
STREAMING_PRESSURE_TEMPERATURE=1.0
STREAMING_PRESSURE_TOP_P=1.0
STREAMING_PRESSURE_THINKING_MODE=non-thinking
STREAMING_PRESSURE_TIMEOUT=900
STREAMING_PRESSURE_REQUEST_RETRIES=1
STREAMING_PRESSURE_MAX_TTFT_SECONDS=60
STREAMING_PRESSURE_MAX_ELAPSED_SECONDS=300
STREAMING_PRESSURE_FAIL_ON_SLOW=0
REAL_SCENARIO_REPEAT_COUNT=3
API_REQUEST_RETRIES=1
GENERATION_PROMPT_ROOT=
GENERATION_LANGUAGES=en,zh
GENERATION_THINKING_MODES=non-thinking,think-high,think-max
GENERATION_REPEAT_COUNT=3
GENERATION_TEMPERATURE=1.0
GENERATION_TOP_P=1.0
GENERATION_TIMEOUT=900
GENERATION_MAX_CASE_TOKENS=65536
# Set empty to disable. These are applied only by generation-matrix for
# thinking-mode generation, not by ToolCall-15, so tool-call policy scores
# remain comparable.
GENERATION_THINK_HIGH_TOKEN_BUDGET=4096
# Think Max should normally rely on the model's reasoning-effort behavior
# without a hard hidden-reasoning budget; give the request a larger max_tokens
# ceiling instead.
GENERATION_THINK_MAX_TOKEN_BUDGET=
GENERATION_THINK_MAX_REQUEST_MAX_TOKENS=65536
TOOLCALL15_SCENARIO_SET=en
TOOLCALL15_THINKING_MODES=non-thinking,think-high,think-max
TOOLCALL15_REPEAT_COUNT=3
TOOLCALL15_TEMPERATURE=1.0
TOOLCALL15_TOP_P=1.0
RUN_BENCH_HF=1
RUN_LM_EVAL=1
LM_EVAL_BIN=lm_eval
LM_EVAL_TASKS=gsm8k
LM_EVAL_NUM_FEWSHOT=8
LM_EVAL_NUM_CONCURRENT=4
MTP_LM_EVAL_NUM_CONCURRENT=1
LM_EVAL_MAX_RETRIES=10
LM_EVAL_MAX_GEN_TOKS=2048
LM_EVAL_TIMEOUT_MS=60000
LM_EVAL_TOKENIZER_BACKEND=none
LM_EVAL_BATCH_SIZE=auto
LM_EVAL_COMMAND_TIMEOUT=7200
LM_EVAL_EXTRA_ARGS=
RUN_RANDOM_LONG=1
RANDOM_LONG_CONCURRENCY=1,2
RANDOM_LONG_NUM_PROMPTS=8
RANDOM_LONG_INPUT_LEN=8192
RANDOM_LONG_OUTPUT_LEN=512
RUN_ORACLE_EXPORT=1
VLLM_ENGINE_READY_TIMEOUT_S=3600
B200_EXTRA_SERVE_ARGS=

# Server responsiveness guard defaults.
SERVER_GUARD=1
SERVER_STARTUP_TIMEOUT=1800
SERVER_STARTUP_INTERVAL_SECONDS=15
SERVER_HEALTH_TIMEOUT=10
SERVER_FAILURE_PROBE_TIMEOUT=30
SERVER_FAILURE_GRACE_TIMEOUT=300
SERVER_FAILURE_GRACE_INTERVAL_SECONDS=10
SERVER_RECOVERY_CMD=

# Optional artifact controls.
ARTIFACT_ROOT=
BRANCH_NAME=
RUN_TIMESTAMP=
GPU_TOPOLOGY_SLUG=
SERVE_LOG=
