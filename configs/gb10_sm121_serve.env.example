export PATH="/usr/local/cuda-13.2/bin:$PATH"
export CUDA_HOME="/usr/local/cuda-13.2"
export TRITON_PTXAS_PATH="/usr/local/cuda-13.2/bin/ptxas"
# GB10 is an SM121 target. Use the specific arch values when validating GB10
# builds so local helper compilation does not fan out to the broader SM12x
# family target.
export CUDA_ARCH_LIST="121a"
export TORCH_CUDA_ARCH_LIST="12.1a"
export GPU_TOPOLOGY_SLUG="${GPU_TOPOLOGY_SLUG:-1x_nvidia_gb10}"
export GPU_TOPOLOGY_DEVICE_IDS="${GPU_TOPOLOGY_DEVICE_IDS:-0}"
# The FP4 indexer cache path is currently SM100/B200-specific, not SM12x.
export SERVE_USE_FP4_INDEXER_CACHE="${SERVE_USE_FP4_INDEXER_CACHE:-0}"
# vLLM upstream requires explicit reasoning_start_str / reasoning_end_str for
# ``thinking_token_budget`` to work; the V4 reasoning parser falls back to
# IdentityReasoningParser at server startup and cannot expose them. The
# baseline driver already defaults to the R1/V4 ``<think>`` delimiters; this
# line is a documentation hint only and can stay commented out.
# export SERVE_REASONING_CONFIG='{"reasoning_parser":"deepseek_v4","reasoning_start_str":"<think>","reasoning_end_str":"</think>"}'
# GB10 acceptance is currently no-thinking no-MTP only. The 128K sentinel is
# the required long-context gate; run think-high and MTP separately as
# exploratory, and do not treat think-max as a GB10 gate until 384K+ context is
# reliable.
export GENERATION_THINKING_MODES="${GENERATION_THINKING_MODES:-non-thinking}"
# Keep the required generation gate large enough for checked-in code and HTML
# prompts. Smaller caps such as 4096 are quick-smoke diagnostics only.
export GENERATION_MAX_CASE_TOKENS="${GENERATION_MAX_CASE_TOKENS:-32768}"
export TOOLCALL15_THINKING_MODES="${TOOLCALL15_THINKING_MODES:-non-thinking}"
export LONG_CONTEXT_LINE_COUNT="${LONG_CONTEXT_LINE_COUNT:-4226}"
export LONG_CONTEXT_MAX_TOKENS="${LONG_CONTEXT_MAX_TOKENS:-128}"
export LONG_CONTEXT_THINKING_MODE="${LONG_CONTEXT_THINKING_MODE:-non-thinking}"
export LONG_CONTEXT_TIMEOUT="${LONG_CONTEXT_TIMEOUT:-2400}"
unset PYTORCH_CUDA_ALLOC_CONF
