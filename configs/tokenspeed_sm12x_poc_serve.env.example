export TOKENSPEED_ROOT="${TOKENSPEED_ROOT:-/path/to/tokenspeed}"
export TOKENSPEED_VENV="${TOKENSPEED_VENV:-${TOKENSPEED_ROOT}/.venv}"
export TOKENSPEED_MODEL_ID="${TOKENSPEED_MODEL_ID:-deepseek-ai/DeepSeek-V4-Flash}"
export TOKENSPEED_API_HOST="${TOKENSPEED_API_HOST:-127.0.0.1}"
export TOKENSPEED_API_PORT="${TOKENSPEED_API_PORT:-8000}"

# TokenSpeed native SM12x kernels default to the 120f family target. Keep the
# PyTorch extension arch on the concrete SM120 target unless a specific build
# path has been verified with 12.0f.
export PATH="/usr/local/cuda/bin:${TOKENSPEED_VENV}/bin:${PATH}"
export CUDA_HOME="${CUDA_HOME:-/usr/local/cuda}"
export TRITON_PTXAS_PATH="${TRITON_PTXAS_PATH:-${CUDA_HOME}/bin/ptxas}"
export TOKENSPEED_CUDA_ARCH_LIST="${TOKENSPEED_CUDA_ARCH_LIST:-120f}"
export TORCH_CUDA_ARCH_LIST="${TORCH_CUDA_ARCH_LIST:-12.0a}"
export TOKENSPEED_KERNEL_BACKEND="${TOKENSPEED_KERNEL_BACKEND:-cuda}"
# Default to the installed wheels so compiled extensions such as
# tokenspeed_scheduler_ext are not shadowed by source-only package paths.
export TOKENSPEED_USE_SOURCE_PATH="${TOKENSPEED_USE_SOURCE_PATH:-0}"
# Keep the installed tokenspeed-kernel wheel first unless you are explicitly
# debugging pure-Python kernel package code; the wheel carries CUDA extensions.
export TOKENSPEED_USE_KERNEL_SOURCE_PATH="${TOKENSPEED_USE_KERNEL_SOURCE_PATH:-0}"

# TokenSpeed has no pipeline-parallel mode today. The PoC default mirrors the
# current SM12x vLLM route as attention TP=2 plus expert parallelism.
export TOKENSPEED_ATTN_TP_SIZE="${TOKENSPEED_ATTN_TP_SIZE:-2}"
export TOKENSPEED_ENABLE_EXPERT_PARALLEL="${TOKENSPEED_ENABLE_EXPERT_PARALLEL:-1}"
export TOKENSPEED_KV_CACHE_DTYPE="${TOKENSPEED_KV_CACHE_DTYPE:-fp8}"
export TOKENSPEED_BLOCK_SIZE="${TOKENSPEED_BLOCK_SIZE:-256}"
export TOKENSPEED_GPU_MEMORY_UTILIZATION="${TOKENSPEED_GPU_MEMORY_UTILIZATION:-0.98}"
export TOKENSPEED_MAX_MODEL_LEN="${TOKENSPEED_MAX_MODEL_LEN:-65536}"
export TOKENSPEED_MAX_NUM_SEQS="${TOKENSPEED_MAX_NUM_SEQS:-2}"
export TOKENSPEED_ENFORCE_EAGER="${TOKENSPEED_ENFORCE_EAGER:-1}"
export TOKENSPEED_DISABLE_KVSTORE="${TOKENSPEED_DISABLE_KVSTORE:-1}"

# TokenSpeed does not have a DeepSeek V4 NextN/MTP implementation in this PoC.
export GENERATION_VARIANT="${GENERATION_VARIANT:-tokenspeed-nomtp}"
export BASE_URL="${BASE_URL:-http://${TOKENSPEED_API_HOST}:${TOKENSPEED_API_PORT}}"
export MODEL="${MODEL:-${TOKENSPEED_MODEL_ID}}"
unset PYTORCH_CUDA_ALLOC_CONF
