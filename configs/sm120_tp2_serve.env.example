export PATH="/usr/local/cuda/bin:$PATH"
export CUDA_HOME="/usr/local/cuda"
export TRITON_PTXAS_PATH="/usr/local/cuda/bin/ptxas"
# SM120-specific arch values keep compile time lower than the broader
# SM12x family target. Use 121a / 12.1a when validating SM121.
export CUDA_ARCH_LIST="120a"
export TORCH_CUDA_ARCH_LIST="12.0a"
# Current long-context SM120 TP=2 profiling favors larger sparse-MLA query
# chunks than the vLLM default. Keep this as a profile-level candidate so it can
# be revalidated per branch without changing upstream defaults.
export VLLM_TRITON_MLA_SPARSE="${VLLM_TRITON_MLA_SPARSE:-1}"
export VLLM_TRITON_MLA_SPARSE_QUERY_CHUNK_SIZE="${VLLM_TRITON_MLA_SPARSE_QUERY_CHUNK_SIZE:-512}"
export VLLM_TRITON_MLA_SPARSE_TOPK_CHUNK_SIZE="${VLLM_TRITON_MLA_SPARSE_TOPK_CHUNK_SIZE:-512}"
# vLLM upstream requires explicit reasoning_start_str / reasoning_end_str for
# ``thinking_token_budget`` (used by think-high acceptance) to work. The V4
# reasoning parser falls back to IdentityReasoningParser at server startup and
# cannot expose them. The baseline driver already defaults to the R1/V4
# ``<think>`` delimiters; this line is a documentation hint and can stay
# commented out.
# export SERVE_REASONING_CONFIG='{"reasoning_parser":"deepseek_v4","reasoning_start_str":"<think>","reasoning_end_str":"</think>"}'
unset PYTORCH_CUDA_ALLOC_CONF
